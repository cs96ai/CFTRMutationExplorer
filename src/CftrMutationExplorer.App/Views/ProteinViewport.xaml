<UserControl x:Class="CftrMutationExplorer.App.Views.ProteinViewport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helix="http://helix-toolkit.org/wpf"
             xmlns:vm="clr-namespace:CftrMutationExplorer.App.ViewModels">

    <Grid Background="{StaticResource PrimaryDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Viewport toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceMediumBrush}"
                Padding="8,4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <WrapPanel>
                <TextBlock Text="View:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,6,0" FontSize="11" />

                <Button Content="Reference" Margin="0,0,4,0" Padding="8,3"
                        Command="{Binding SetViewModeCommand}" CommandParameter="ReferenceOnly"
                        FontSize="11" />
                <Button Content="Mutant" Margin="0,0,4,0" Padding="8,3"
                        Command="{Binding SetViewModeCommand}" CommandParameter="MutantOnly"
                        FontSize="11" />
                <Button Content="Overlay" Margin="0,0,4,0" Padding="8,3"
                        Command="{Binding SetViewModeCommand}" CommandParameter="Overlay"
                        FontSize="11" />
                <Button Content="Mutation Site" Margin="0,0,8,0" Padding="8,3"
                        Command="{Binding FocusOnMutationSiteCommand}"
                        FontSize="11" />

                <Separator Background="{StaticResource BorderBrush}" Width="1" Margin="4,2" />

                <TextBlock Text="Color:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="4,0,6,0" FontSize="11" />
                <ComboBox SelectedIndex="0" Width="120" FontSize="11"
                          SelectionChanged="ColorSchemeChanged">
                    <ComboBoxItem Content="By Chain" />
                    <ComboBoxItem Content="By Residue Type" />
                    <ComboBoxItem Content="By B-Factor" />
                    <ComboBoxItem Content="Single Color" />
                </ComboBox>

                <Separator Background="{StaticResource BorderBrush}" Width="1" Margin="4,2" />

                <TextBlock Text="Size:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="4,0,6,0" FontSize="11" />
                <Slider Value="{Binding AtomRadius}" Minimum="0.1" Maximum="1.5"
                        Width="80" VerticalAlignment="Center"
                        ToolTip="Atom radius" />
            </WrapPanel>
        </Border>

        <!-- 3D Viewport -->
        <helix:HelixViewport3D x:Name="Viewport3D" Grid.Row="1"
                                Background="#FF1B2838"
                                ShowViewCube="True"
                                ShowCoordinateSystem="True"
                                ZoomExtentsWhenLoaded="True"
                                ShowFrameRate="False"
                                InfoForeground="White"
                                RotateGesture="LeftClick"
                                PanGesture="RightClick"
                                ZoomRectangleGesture="Control+RightClick">
            <helix:DefaultLights />
            <ModelVisual3D Content="{Binding SceneModel}" />
        </helix:HelixViewport3D>

        <!-- Viewport info bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceMediumBrush}"
                Padding="8,3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock Text="{Binding ViewportInfoText}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="Reset Camera" Padding="6,2" FontSize="10"
                            Click="ResetCamera_Click" Margin="4,0,0,0" />
                    <Button Content="Zoom All" Padding="6,2" FontSize="10"
                            Click="ZoomExtents_Click" Margin="4,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
