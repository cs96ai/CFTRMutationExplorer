<UserControl x:Class="CftrMutationExplorer.App.Views.Phase5ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:vm="clr-namespace:CftrMutationExplorer.App.ViewModels"
             Background="{StaticResource PrimaryDarkBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Left: Config Panel -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceDarkBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel>
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="RESCORING CONFIG" Style="{StaticResource SectionHeader}"
                                   VerticalAlignment="Center" />
                        <ContentControl Style="{StaticResource InfoIcon}" DockPanel.Dock="Right">
                            <ContentControl.ToolTip>
                                <ToolTip MaxWidth="380" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="Phase 5: Second-Stage Rescoring" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
                                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                            <Run Text="Takes top N candidates from Stage 1 (NSGA-II), each a full CFTR CDS (~4440 nt) with different synonymous codons. "/>
                                            <Run Text="Computes 12 new metrics: RNA structure (global MFE, 5' accessibility, early CDS penalty), sliding-window GC (30/50 nt, variance), motif risk (homopolymers, dinucleotide repeats, AU-rich, forbidden motifs), codon diversity (repetition, runs, autocorrelation). "/>
                                            <Run Text="Reranks by weighted composite with saturation dampening; applies Hamming-distance diversity filter."/>
                                        </TextBlock>
                                        <TextBlock Text="Why it's slow" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBlueBrush}" Margin="0,8,0,4" />
                                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                            <Run Text="~13 RNA folds per candidate (global windows, 5' accessibility, early CDS penalty). "/>
                                            <Run Text="50 candidates ≈ 650 folds. "/>
                                            <Run Text="Uses ViennaRNACuda or ViennaRNA when available; Nussinov fallback. Folding is O(n³) per window."/>
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </ContentControl.ToolTip>
                        </ContentControl>
                    </DockPanel>

                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Preset" Style="{StaticResource MetricLabel}" Margin="0,0,0,2" />
                            <ComboBox ItemsSource="{Binding AvailablePresets}"
                                      SelectedItem="{Binding SelectedPreset}"
                                      Margin="0,0,0,6" />

                            <TextBlock Text="Top N" Style="{StaticResource MetricLabel}" Margin="0,0,0,2" />
                            <TextBox Text="{Binding TopN}" Margin="0,0,0,6" />

                            <TextBlock Text="Run ID (optional)" Style="{StaticResource MetricLabel}" Margin="0,0,0,2" />
                            <TextBox Text="{Binding RunId}" Margin="0,0,0,8" />

                            <Button Content="Run Rescore" Style="{StaticResource AccentButton}"
                                    Command="{Binding RescoreCandidatesCommand}"
                                    IsEnabled="{Binding IsRescoring, Converter={StaticResource InverseBool}}"
                                    ToolTip="Run Phase 5 rescoring on top N candidates from Stage 1. Computes RNA structure, GC windows, motif risk, codon diversity. May take a minute." />

                            <StackPanel Margin="0,8,0,0"
                                        Visibility="{Binding IsRescoring, Converter={StaticResource BoolToVisibility}}">
                                <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"
                                             Height="6" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding ProgressText}"
                                           Foreground="{StaticResource AccentBlueBrush}" FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,8" />

                    <TextBlock Text="{Binding SummaryText}"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Center: Main content with tabs -->
        <TabControl Grid.Column="1" Background="{StaticResource PrimaryDarkBrush}"
                    BorderBrush="{StaticResource BorderBrush}" Padding="0">

            <!-- Tab 1: All Candidates -->
            <TabItem Header="All Candidates">
                <Grid Margin="16">
                    <DataGrid ItemsSource="{Binding AllCandidates}"
                              SelectedItem="{Binding SelectedCandidate}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rank (Phase5)" Binding="{Binding RankPhase5}" Width="90" />
                            <DataGridTextColumn Header="Rank Change" Binding="{Binding RankChange}" Width="80" />
                            <DataGridTextColumn Header="CAI" Binding="{Binding Cai, StringFormat=F3}" Width="60" />
                            <DataGridTextColumn Header="GC" Binding="{Binding GcScore, StringFormat=F3}" Width="60" />
                            <DataGridTextColumn Header="CpG" Binding="{Binding CpgScore, StringFormat=F3}" Width="60" />
                            <DataGridTextColumn Header="5' Structure" Binding="{Binding Structure5Prime, StringFormat=F3}" Width="85" />
                            <DataGridTextColumn Header="GC Window" Binding="{Binding GcWindow30, StringFormat=F3}" Width="75" />
                            <DataGridTextColumn Header="Codon Div." Binding="{Binding CodonDiversity, StringFormat=F3}" Width="80" />
                            <DataGridTextColumn Header="Motif Risk" Binding="{Binding MotifRisk, StringFormat=F3}" Width="75" />
                            <DataGridTextColumn Header="Legacy Composite" Binding="{Binding CompositeLegacy, StringFormat=F3}" Width="100" />
                            <DataGridTextColumn Header="Phase5 Composite" Binding="{Binding CompositePhase5, StringFormat=F3}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Diverse Top-K -->
            <TabItem Header="Diverse Top-K">
                <Grid Margin="16">
                    <DataGrid ItemsSource="{Binding DiverseCandidates}"
                              SelectedItem="{Binding SelectedCandidate}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rank (Phase5)" Binding="{Binding RankPhase5}" Width="90" />
                            <DataGridTextColumn Header="Rank Change" Binding="{Binding RankChange}" Width="80" />
                            <DataGridTextColumn Header="CAI" Binding="{Binding Cai, StringFormat=F3}" Width="60" />
                            <DataGridTextColumn Header="GC" Binding="{Binding GcScore, StringFormat=F3}" Width="60" />
                            <DataGridTextColumn Header="CpG" Binding="{Binding CpgScore, StringFormat=F3}" Width="60" />
                            <DataGridTextColumn Header="5' Structure" Binding="{Binding Structure5Prime, StringFormat=F3}" Width="85" />
                            <DataGridTextColumn Header="GC Window" Binding="{Binding GcWindow30, StringFormat=F3}" Width="75" />
                            <DataGridTextColumn Header="Codon Div." Binding="{Binding CodonDiversity, StringFormat=F3}" Width="80" />
                            <DataGridTextColumn Header="Motif Risk" Binding="{Binding MotifRisk, StringFormat=F3}" Width="75" />
                            <DataGridTextColumn Header="Legacy Composite" Binding="{Binding CompositeLegacy, StringFormat=F3}" Width="100" />
                            <DataGridTextColumn Header="Phase5 Composite" Binding="{Binding CompositePhase5, StringFormat=F3}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 4: Log -->
            <TabItem Header="Log">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Phase 5 rescoring log — shows progress and metrics during rescoring"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,8" />
                    <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding RescoreLog, Mode=OneWay}"
                                     IsReadOnly="True" TextWrapping="NoWrap"
                                     FontFamily="Consolas" FontSize="11"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     Padding="0" Margin="0"
                                     VerticalAlignment="Stretch" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 3: Comparison Chart -->
            <TabItem Header="Comparison Chart">
                <Grid Margin="16">
                    <oxy:PlotView Model="{Binding ComparisonChart}"
                                 Background="Transparent" MinHeight="250">
                        <oxy:PlotView.DefaultTrackerTemplate>
                            <ControlTemplate>
                                <oxy:TrackerControl Position="{Binding Position}"
                                                    Background="#DD1E1E28"
                                                    BorderBrush="#FF4488CC"
                                                    BorderThickness="1">
                                    <TextBlock Text="{Binding}" Foreground="#FFCCCCDD" FontSize="11" Margin="6,4" />
                                </oxy:TrackerControl>
                            </ControlTemplate>
                        </oxy:PlotView.DefaultTrackerTemplate>
                    </oxy:PlotView>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Right: Detail Panel -->
        <Border Grid.Column="2" Background="{StaticResource SurfaceDarkBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel>
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="CANDIDATE DETAILS" Style="{StaticResource SectionHeader}" VerticalAlignment="Center" />
                        <ContentControl Style="{StaticResource InfoIcon}" DockPanel.Dock="Right">
                            <ContentControl.ToolTip>
                                <ToolTip MaxWidth="340" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="Candidate details" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
                                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                            Select a candidate in the All Candidates or Diverse Top-K table to see its full metrics and explanation here.
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </ContentControl.ToolTip>
                        </ContentControl>
                    </DockPanel>

                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8"
                            Visibility="{Binding SelectedCandidate, Converter={StaticResource NullToCollapsed}}">
                        <TextBlock Text="{Binding SelectedCandidateDetails}"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Select a candidate to view details."
                               Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="{Binding SelectedCandidate, Converter={StaticResource NullToVisible}}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
