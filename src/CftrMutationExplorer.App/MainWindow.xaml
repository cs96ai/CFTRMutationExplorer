<Window x:Class="CftrMutationExplorer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CftrMutationExplorer.App.ViewModels"
        xmlns:views="clr-namespace:CftrMutationExplorer.App.Views"
        mc:Ignorable="d"
        Title="CFTR Mutation Explorer"
        Height="820" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        d:DataContext="{d:DesignInstance vm:MainWindowViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="CFTR Mutation Explorer"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               VerticalAlignment="Center" Margin="0,0,24,0" />

                    <Button x:Name="LoadDemoButton" Content="Load Demo Data"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding LoadDemoDataCommand}"
                            ToolTip="Load sample CFTR normal and F508del structures"
                            Margin="0,0,8,0" />

                    <Button x:Name="RunComparisonButton" Content="Run Comparison"
                            Command="{Binding RunComparisonCommand}"
                            IsEnabled="{Binding IsComparisonAvailable}"
                            ToolTip="Compare loaded reference and mutant structures"
                            Margin="0,0,8,0" />
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           DockPanel.Dock="Right"
                           FontSize="12" />
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftColumn" Width="300" MinWidth="200" />
                <ColumnDefinition x:Name="LeftSplitterColumn" Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightSplitterColumn" Width="Auto" />
                <ColumnDefinition x:Name="RightColumn" Width="320" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Structure Loaders -->
            <Border x:Name="LeftPanel" Grid.Column="0" Background="{StaticResource SurfaceDarkBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="STRUCTURES" Style="{StaticResource SectionHeader}" />

                        <!-- Reference Structure -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel DataContext="{Binding ReferenceLoader}">
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentGreenBrush}"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Button Content="Browse PDB File..."
                                        Command="{Binding BrowseAndLoadCommand}"
                                        Margin="0,0,0,8" />

                                <ProgressBar Value="{Binding LoadProgress}"
                                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                                             Margin="0,0,0,4" />

                                <TextBlock Text="{Binding FileName}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,0,2"
                                           Visibility="{Binding HasStructure, Converter={StaticResource BoolToVisibility}}" />

                                <TextBlock Text="{Binding StructureSummary}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11" TextWrapping="Wrap" />

                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="{StaticResource AccentRedBrush}"
                                           FontSize="11" TextWrapping="Wrap"
                                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}" />
                            </StackPanel>
                        </Border>

                        <!-- Mutant Structure -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel DataContext="{Binding MutantLoader}">
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentOrangeBrush}"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Button Content="Browse PDB File..."
                                        Command="{Binding BrowseAndLoadCommand}"
                                        Margin="0,0,0,8" />

                                <ProgressBar Value="{Binding LoadProgress}"
                                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                                             Margin="0,0,0,4" />

                                <TextBlock Text="{Binding FileName}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11" Margin="0,0,0,2"
                                           Visibility="{Binding HasStructure, Converter={StaticResource BoolToVisibility}}" />

                                <TextBlock Text="{Binding StructureSummary}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11" TextWrapping="Wrap" />

                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="{StaticResource AccentRedBrush}"
                                           FontSize="11" TextWrapping="Wrap"
                                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}" />
                            </StackPanel>
                        </Border>

                        <!-- Quick Comparison Stats -->
                        <Border Style="{StaticResource CardBorder}"
                                Visibility="{Binding ComparisonSummary.HasResult, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="QUICK STATS" Style="{StaticResource SectionHeader}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                        <TextBlock Text="Ref Residues" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding ComparisonSummary.ReferenceResidueCount}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="Mut Residues" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding ComparisonSummary.MutantResidueCount}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                        <TextBlock Text="Ref Atoms" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding ComparisonSummary.ReferenceAtomCount}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="Mut Atoms" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding ComparisonSummary.MutantAtomCount}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,4">
                                        <TextBlock Text="Simplified RMSD" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding ComparisonSummary.RmsdDisplay}"
                                                   Style="{StaticResource MetricValue}"
                                                   Foreground="{StaticResource AccentBlueBrush}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter x:Name="LeftSplitter" Grid.Column="1" Width="4" Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Center: Tab Content -->
            <TabControl x:Name="MainTabControl" Grid.Column="2" SelectedIndex="{Binding SelectedTabIndex}"
                        Background="{StaticResource PrimaryDarkBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        Padding="0"
                        SelectionChanged="MainTabControl_SelectionChanged">

                <!-- 3D Viewport Tab -->
                <TabItem Header="3D Viewport">
                    <views:ProteinViewport DataContext="{Binding Viewport}" />
                </TabItem>

                <!-- Overview Tab -->
                <TabItem Header="Overview">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="CFTR Mutation Explorer" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,16" FontSize="13" LineHeight="20">
                                Explore how the ΔF508 mutation affects the CFTR protein structure.
                                Load a reference (normal) and mutant protein structure, compare them,
                                inspect the mutation region, and analyze structural differences.
                            </TextBlock>

                            <TextBlock Text="GETTING STARTED" Style="{StaticResource SectionHeader}" Margin="0,8,0,8" />

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">1. Load Structures</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                        Use the left panel to load PDB files, or click "Load Demo Data" to use sample CFTR structures.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">2. Compare Structures</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                        Once both structures are loaded, comparison runs automatically. View results in the Comparison tab.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">3. Analyze Mutation</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                        Switch to the Mutation Analysis tab to inspect the F508 deletion region and its structural impact.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4">4. Inspect Residues</TextBlock>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                        Use the right panel to search, filter, and inspect individual residues and their neighborhoods.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Comparison Tab -->
                <TabItem Header="Comparison">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                                  DataContext="{Binding ComparisonSummary}">
                        <StackPanel>
                            <!-- Empty state -->
                            <TextBlock Text="Load both structures to see comparison results."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14" Margin="0,20,0,0"
                                       Visibility="{Binding HasResult, Converter={StaticResource InverseBoolToVisibility}}" />

                            <StackPanel Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="STRUCTURE COMPARISON" Style="{StaticResource SectionHeader}" />

                                <!-- Files -->
                                <Border Style="{StaticResource CardBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Reference" Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding ReferenceFileName}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentGreenBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Mutant" Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding MutantFileName}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentOrangeBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Metrics grid -->
                                <Border Style="{StaticResource CardBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="RMSD" Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding RmsdDisplay}" Style="{StaticResource MetricValue}"
                                                       Foreground="{StaticResource AccentBlueBrush}" FontSize="15" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <TextBlock Text="Residue Δ" Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding ResidueDifference}" Style="{StaticResource MetricValue}" FontSize="15" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                            <TextBlock Text="Missing (Mut)" Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding MissingInMutantCount}" Style="{StaticResource MetricValue}"
                                                       Foreground="{StaticResource AccentRedBrush}" FontSize="15" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="Altered" Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding AlteredResidueCount}" Style="{StaticResource MetricValue}"
                                                       Foreground="{StaticResource AccentOrangeBrush}" FontSize="15" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Missing residues -->
                                <TextBlock Text="MISSING IN MUTANT" Style="{StaticResource SectionHeader}" Margin="0,8,0,4" />
                                <ItemsControl ItemsSource="{Binding MissingInMutant}" Margin="0,0,0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceMediumBrush}"
                                                    CornerRadius="3" Padding="8,4" Margin="0,0,0,2">
                                                <TextBlock Text="{Binding}" Foreground="{StaticResource AccentRedBrush}" FontSize="12" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Residue comparison table -->
                                <TextBlock Text="RESIDUE-BY-RESIDUE COMPARISON" Style="{StaticResource SectionHeader}" Margin="0,8,0,4" />
                                <DataGrid ItemsSource="{Binding ResidueComparisons}"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Chain" Binding="{Binding ChainId}" Width="50" />
                                        <DataGridTextColumn Header="#" Binding="{Binding ResidueNumber}" Width="50" />
                                        <DataGridTextColumn Header="Reference" Binding="{Binding ReferenceResidueName}" Width="80" />
                                        <DataGridTextColumn Header="Mutant" Binding="{Binding MutantResidueName}" Width="80" />
                                        <DataGridTextColumn Header="Centroid Δ (Å)" Binding="{Binding CentroidDistance, StringFormat=F2}" Width="100" />
                                        <DataGridCheckBoxColumn Header="Altered" Binding="{Binding IsAltered, Mode=OneWay}" Width="60" IsReadOnly="True" />
                                        <DataGridCheckBoxColumn Header="Missing" Binding="{Binding IsMissing, Mode=OneWay}" Width="60" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Warnings -->
                                <ItemsControl ItemsSource="{Binding Warnings}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{StaticResource AccentOrangeBrush}" FontSize="11" Margin="0,2" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Mutation Analysis Tab -->
                <TabItem Header="Mutation Analysis">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                                  DataContext="{Binding MutationAnalysis}">
                        <StackPanel>
                            <TextBlock Text="Load both structures to see mutation analysis."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14" Margin="0,20,0,0"
                                       Visibility="{Binding HasAnalysis, Converter={StaticResource InverseBoolToVisibility}}" />

                            <StackPanel Visibility="{Binding HasAnalysis, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="ΔF508 MUTATION ANALYSIS" Style="{StaticResource SectionHeader}" />

                                <!-- Mutation summary -->
                                <Border Style="{StaticResource CardBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Mutation Summary" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <TextBlock Text="{Binding MutationSummary}" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20" />
                                    </StackPanel>
                                </Border>

                                <!-- Side by side residue info -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="Reference Residue" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentGreenBrush}" Margin="0,0,0,6" />
                                            <TextBlock Text="{Binding ReferenceResidueInfo}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontFamily="Consolas" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="Mutant Residue" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentOrangeBrush}" Margin="0,0,0,6" />
                                            <TextBlock Text="{Binding MutantResidueInfo}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontFamily="Consolas" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Folding assessment -->
                                <Border Style="{StaticResource CardBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Folding Impact Assessment" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentRedBrush}" Margin="0,0,0,6" />
                                        <TextBlock Text="{Binding FoldingAssessment}" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextSecondaryBrush}" LineHeight="20" />
                                    </StackPanel>
                                </Border>

                                <!-- Structural impact -->
                                <Border Style="{StaticResource CardBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Structural Impact Summary" FontWeight="SemiBold" Margin="0,0,0,6" />
                                        <TextBlock Text="{Binding StructuralImpactSummary}" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontFamily="Consolas" FontSize="12" />
                                    </StackPanel>
                                </Border>

                                <!-- Neighbor tables -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="REFERENCE NEIGHBORS (10Å)" Style="{StaticResource SectionHeader}" />
                                        <DataGrid ItemsSource="{Binding ReferenceNeighbors}" MaxHeight="250">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Residue" Binding="{Binding Label}" Width="*" />
                                                <DataGridTextColumn Header="Chain" Binding="{Binding ChainId}" Width="50" />
                                                <DataGridTextColumn Header="Dist" Binding="{Binding DistanceDisplay}" Width="60" />
                                                <DataGridTextColumn Header="Atoms" Binding="{Binding AtomCount}" Width="50" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="MUTANT NEIGHBORS (10Å)" Style="{StaticResource SectionHeader}" />
                                        <DataGrid ItemsSource="{Binding MutantNeighbors}" MaxHeight="250">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Residue" Binding="{Binding Label}" Width="*" />
                                                <DataGridTextColumn Header="Chain" Binding="{Binding ChainId}" Width="50" />
                                                <DataGridTextColumn Header="Dist" Binding="{Binding DistanceDisplay}" Width="60" />
                                                <DataGridTextColumn Header="Atoms" Binding="{Binding AtomCount}" Width="50" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Annotations Tab -->
                <TabItem Header="Annotations">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                                  DataContext="{Binding AnnotationList}">
                        <StackPanel>
                            <TextBlock Text="ANNOTATIONS" Style="{StaticResource SectionHeader}" />

                            <!-- Add new annotation -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="New Annotation" FontWeight="SemiBold" Margin="0,0,0,8" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Title" Style="{StaticResource MetricLabel}" Margin="0,0,0,2" />
                                            <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                            <TextBlock Text="Category" Style="{StaticResource MetricLabel}" Margin="0,0,0,2" />
                                            <ComboBox ItemsSource="{Binding AvailableCategories}"
                                                      SelectedItem="{Binding NewCategory}" Margin="0,0,0,8" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Target Residue #" Style="{StaticResource MetricLabel}" Margin="0,0,0,2" />
                                            <TextBox Text="{Binding NewTargetResidueNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                            <TextBlock Text="Chain" Style="{StaticResource MetricLabel}" Margin="0,0,0,2" />
                                            <TextBox Text="{Binding NewTargetChainId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Note" Style="{StaticResource MetricLabel}" Margin="0,0,0,2" />
                                    <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" Height="60" TextWrapping="Wrap" Margin="0,0,0,8" />

                                    <Button Content="Add Annotation" Style="{StaticResource AccentButton}"
                                            Command="{Binding AddAnnotationCommand}" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <!-- Annotation list -->
                            <TextBlock Text="SAVED ANNOTATIONS" Style="{StaticResource SectionHeader}" Margin="0,8,0,4" />

                            <Button Content="Refresh" Command="{Binding LoadAnnotationsCommand}"
                                    HorizontalAlignment="Left" Margin="0,0,0,8" />

                            <DataGrid ItemsSource="{Binding Annotations}"
                                      SelectedItem="{Binding SelectedAnnotation}"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" />
                                    <DataGridTextColumn Header="Residue" Binding="{Binding TargetResidueNumber}" Width="70" />
                                    <DataGridTextColumn Header="Chain" Binding="{Binding TargetChainId}" Width="50" />
                                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=g}" Width="130" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Selected annotation details -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0"
                                    Visibility="{Binding SelectedAnnotation, Converter={StaticResource NullToCollapsed}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedAnnotation.Title}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding SelectedAnnotation.Note}" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Delete" Command="{Binding DeleteAnnotationCommand}" Margin="0,0,8,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" Margin="0,8,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Binding Pockets Tab -->
                <TabItem Header="Candidate Pockets">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                                  DataContext="{Binding BindingPockets}">
                        <StackPanel>
                            <TextBlock Text="BINDING POCKET CANDIDATES" Style="{StaticResource SectionHeader}" />
                            <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,12" TextWrapping="Wrap">
                                Demo heuristic screening — identifies clusters of binding-relevant residues.
                                Not a validated drug docking algorithm.
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="Detect Pockets" Style="{StaticResource AccentButton}"
                                        Command="{Binding DetectPocketsCommand}" Margin="0,0,12,0" />

                                <TextBlock Text="Radius (Å):" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0" FontSize="11" />
                                <TextBox Text="{Binding ClusterRadius}" Width="50" Margin="0,0,12,0" />

                                <TextBlock Text="Min residues:" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0" FontSize="11" />
                                <TextBox Text="{Binding MinResidues}" Width="50" />
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding Pockets}"
                                      SelectedItem="{Binding SelectedPocket}"
                                      MaxHeight="250"
                                      Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibility}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Pocket" Binding="{Binding Label}" Width="80" />
                                    <DataGridTextColumn Header="Residues" Binding="{Binding ResidueCount}" Width="65" />
                                    <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" Width="80" />
                                    <DataGridTextColumn Header="Volume" Binding="{Binding VolumeDisplay}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Style="{StaticResource CardBorder}" Margin="0,8,0,0"
                                    Visibility="{Binding SelectedPocket, Converter={StaticResource NullToCollapsed}}">
                                <TextBlock Text="{Binding SelectedPocketDetails}"
                                           TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </Border>

                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" Margin="0,8,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Export Tab -->
                <TabItem Header="Export">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                                  DataContext="{Binding Export}">
                        <StackPanel>
                            <TextBlock Text="EXPORT &amp; REPORTING" Style="{StaticResource SectionHeader}" />

                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Comparison Report" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                        Export a Markdown report including structure stats, comparison metrics,
                                        altered residues, and annotations.
                                    </TextBlock>
                                    <Button Content="Export Report (.md)"
                                            Command="{Binding ExportReportCommand}"
                                            IsEnabled="{Binding CanExport}"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Annotations" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                        Export all saved annotations to CSV format for external analysis.
                                    </TextBlock>
                                    <Button Content="Export Annotations (.csv)"
                                            Command="{Binding ExportAnnotationsCommand}"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Viewport Screenshot" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                        Capture the current 3D viewport as a PNG image.
                                    </TextBlock>
                                    <Button Content="Export Screenshot (.png)"
                                            Command="{Binding ExportScreenshotCommand}"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       FontSize="12" Margin="0,12,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- mRNA Therapy Designer Tab -->
                <TabItem Header="mRNA Therapy">
                    <views:MrnaDesignerView DataContext="{Binding MrnaDesigner}" />
                </TabItem>

                <!-- Structure Details Tab -->
                <TabItem Header="Structure Details">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="LOADED STRUCTURE DETAILS" Style="{StaticResource SectionHeader}" />

                            <!-- Reference details -->
                            <Border Style="{StaticResource CardBorder}"
                                    Visibility="{Binding ReferenceLoader.HasStructure, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding ReferenceLoader.Label}" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentGreenBrush}" Margin="0,0,0,6" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas" FontSize="12">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="File: {0}&#x0a;Chains: {1}&#x0a;Summary: {2}">
                                                <Binding Path="ReferenceLoader.FileName" />
                                                <Binding Path="ComparisonSummary.ReferenceChainCount" />
                                                <Binding Path="ReferenceLoader.StructureSummary" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Mutant details -->
                            <Border Style="{StaticResource CardBorder}"
                                    Visibility="{Binding MutantLoader.HasStructure, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding MutantLoader.Label}" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentOrangeBrush}" Margin="0,0,0,6" />
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas" FontSize="12">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="File: {0}&#x0a;Chains: {1}&#x0a;Summary: {2}">
                                                <Binding Path="MutantLoader.FileName" />
                                                <Binding Path="ComparisonSummary.MutantChainCount" />
                                                <Binding Path="MutantLoader.StructureSummary" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="No structures loaded yet."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14" Margin="0,8,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ReferenceLoader.HasStructure}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <GridSplitter x:Name="RightSplitter" Grid.Column="3" Width="4" Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Right Panel: Residue Inspector -->
            <Border x:Name="RightPanel" Grid.Column="4" Background="{StaticResource SurfaceDarkBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid DataContext="{Binding ResidueInspector}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="180" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="12,8,12,0">
                        <TextBlock Text="RESIDUE INSPECTOR" Style="{StaticResource SectionHeader}" />
                    </StackPanel>

                    <!-- Search and filter -->
                    <StackPanel Grid.Row="1" Margin="12,4,12,4">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Search residue # or name..."
                                 Margin="0,0,0,4" />
                        <DockPanel>
                            <ComboBox ItemsSource="{Binding AvailableChains}"
                                      SelectedItem="{Binding ChainFilter}"
                                      DockPanel.Dock="Left" Width="120" Margin="0,0,4,0" />
                            <Button Content="Go to 508"
                                    Command="{Binding JumpToResidue508Command}"
                                    DockPanel.Dock="Right" />
                        </DockPanel>
                    </StackPanel>

                    <!-- Residue list -->
                    <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredResidues}"
                              SelectedItem="{Binding SelectedResidue}"
                              Margin="12,4,12,4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding SequenceNumber}" Width="45" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="50" />
                            <DataGridTextColumn Header="AA" Binding="{Binding SingleLetter}" Width="30" />
                            <DataGridTextColumn Header="Ch" Binding="{Binding ChainId}" Width="30" />
                            <DataGridTextColumn Header="Atoms" Binding="{Binding AtomCount}" Width="45" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="3" Height="4" Background="{StaticResource BorderBrush}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center" />

                    <!-- Selected residue details -->
                    <Border Grid.Row="4" Margin="12,4,12,8">
                        <StackPanel>
                            <TextBlock Text="RESIDUE DETAILS" Style="{StaticResource SectionHeader}" />
                            <TextBlock Text="{Binding SelectedResidueDetails}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="Consolas" FontSize="11"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Select a residue to view details"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"
                                       Visibility="{Binding SelectedResidue, Converter={StaticResource NullToVisible}}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,4">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" VerticalAlignment="Center" />
                <TextBlock Text="CFTR Mutation Explorer v1.0 — Demo Application"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" VerticalAlignment="Center"
                           HorizontalAlignment="Right" DockPanel.Dock="Right" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
